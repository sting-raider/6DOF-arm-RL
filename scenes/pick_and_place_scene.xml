<mujoco model="pick_and_place">

  <compiler angle="radian"/>

  <option timestep="0.002" integrator="RK4" gravity="0 0 -9.81" solver="Newton"
          noslip_iterations="5" noslip_tolerance="1e-10"/>

  <size nconmax="200" njmax="200"/>

  <!-- Defaults -->
  <default>
    <geom rgba="0.5 0.5 0.5 1" density="800" contype="2" conaffinity="2" friction="1.0 0.1 0.1"/>
    <joint limited="true" armature="0.01" frictionloss="0.05"/>
    <motor ctrllimited="true" ctrlrange="-1 1"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.9 0.9 0.9" rgb2="0.5 0.5 0.5" width="256" height="256"/>
    <texture name="table_tex" type="2d" builtin="checker" rgb1="0.7 0.7 0.7" rgb2="0.3 0.3 0.3" width="256" height="256"/>
    <material name="table_mat" texture="table_tex" shininess="0.1"/>
    <material name="basket_mat" rgba="0.6 0.3 0.1 1" shininess="0.5"/>
    <material name="arm_mat" rgba="0.3 0.5 0.7 1" shininess="0.5"/>
    <material name="gripper_mat" rgba="0.5 0.5 0.5 1" shininess="0.8"/>
    <material name="object_mat" rgba="0.8 0.3 0.2 1" shininess="0.6"/>
    <material name="ground_mat" rgba="0.2 0.2 0.2 1"/>
  </asset>

  <worldbody>
    <!-- Ground plane -->
    <geom name="ground" type="plane" size="5 5 0.01" material="ground_mat"/>

    <!-- Table -->
    <body name="table" pos="0 0 0.79">
      <geom name="table_surface" type="box" size="0.3 0.2 0.01" material="table_mat"
            friction="1.0 0.1 0.1"/>
      <geom name="table_leg1" type="cylinder" size="0.02 0.4" pos="-0.25 -0.15 -0.4"/>
      <geom name="table_leg2" type="cylinder" size="0.02 0.4" pos="0.25 -0.15 -0.4"/>
      <geom name="table_leg3" type="cylinder" size="0.02 0.4" pos="-0.25 0.15 -0.4"/>
      <geom name="table_leg4" type="cylinder" size="0.02 0.4" pos="0.25 0.15 -0.4"/>
    </body>

    <!-- Basket -->
    <body name="basket" pos="0.4 0 0.8">
      <geom name="basket_bottom" type="box" size="0.075 0.075 0.005" material="basket_mat"
            pos="0 0 -0.005" friction="1.0 0.1 0.1"/>
      <geom name="basket_wall1" type="box" size="0.075 0.005 0.05" material="basket_mat"
            pos="0 0.08 0.045" friction="1.0 0.1 0.1"/>
      <geom name="basket_wall2" type="box" size="0.075 0.005 0.05" material="basket_mat"
            pos="0 -0.08 0.045" friction="1.0 0.1 0.1"/>
      <geom name="basket_wall3" type="box" size="0.005 0.075 0.05" material="basket_mat"
            pos="0.08 0 0.045" friction="1.0 0.1 0.1"/>
      <geom name="basket_wall4" type="box" size="0.005 0.075 0.05" material="basket_mat"
            pos="-0.08 0 0.045" friction="1.0 0.1 0.1"/>
    </body>

    <!-- Graspable Object -->
    <body name="object" pos="0 0 0.82">
      <freejoint name="object_free"/>
      <inertial pos="0 0 0" mass="0.1" diaginertia="0.0001 0.0001 0.0001"/>
      <geom name="object_geom" type="box" size="0.02 0.02 0.02" material="object_mat"
            friction="1.0 0.1 0.1"/>
    </body>

    <!-- 6-DOF KUKA iiwa Arm -->
    <body name="kuka_base" pos="-0.15 0 0.02">
      <geom name="base_geom" type="cylinder" size="0.04 0.02" material="arm_mat"/>
      
      <!-- Joint 1: Base rotation -->
      <body name="link1" pos="0 0 0.02">
        <joint name="joint1" type="hinge" axis="0 0 1"
               pos="0 0 0" limited="true" range="-3.14159 3.14159" damping="0.5"/>
        <geom name="link1_geom" type="capsule" size="0.03 0.15" pos="0 0 0.15" material="arm_mat"/>
        
        <!-- Joint 2: Shoulder -->
        <body name="link2" pos="0 0 0.3">
          <joint name="joint2" type="hinge" axis="0 -1 0"
                 pos="0 0 0" limited="true" range="-1.5708 1.5708" damping="0.5"/>
          <geom name="link2_geom" type="capsule" size="0.03 0.15" pos="0 0 0.15" material="arm_mat"/>
          
          <!-- Joint 3: Elbow -->
          <body name="link3" pos="0 0 0.3">
            <joint name="joint3" type="hinge" axis="0 1 0"
                   pos="0 0 0" limited="true" range="-3.14159 3.14159" damping="0.5"/>
            <geom name="link3_geom" type="capsule" size="0.028 0.15" pos="0 0 0.15" material="arm_mat"/>
            
            <!-- Joint 4: Wrist 1 -->
            <body name="link4" pos="0 0 0.3">
              <joint name="joint4" type="hinge" axis="0 1 0"
                     pos="0 0 0" limited="true" range="-3.14159 3.14159" damping="0.3"/>
              <geom name="link4_geom" type="capsule" size="0.025 0.13" pos="0 0 0.13" material="arm_mat"/>
              
              <!-- Joint 5: Wrist 2 -->
              <body name="link5" pos="0 0 0.26">
                <joint name="joint5" type="hinge" axis="0 -1 0"
                       pos="0 0 0" limited="true" range="-1.5708 1.5708" damping="0.3"/>
                <geom name="link5_geom" type="capsule" size="0.022 0.1" pos="0 0 0.1" material="arm_mat"/>
                
                <!-- Joint 6: Wrist 3 -->
                <body name="link6" pos="0 0 0.2">
                  <joint name="joint6" type="hinge" axis="0 0 1"
                         pos="0 0 0" limited="true" range="-3.14159 3.14159" damping="0.3"/>
                  <geom name="link6_geom" type="capsule" size="0.02 0.05" pos="0 0 0.05" material="arm_mat"/>
                  
                  <!-- End effector -->
                  <body name="ee_mount" pos="0 0 0.1">
                    <!-- Gripper left finger -->
                    <body name="gripper_left" pos="0 -0.025 0">
                      <joint name="gripper_left_joint" type="slide" axis="0 -1 0"
                             pos="0 0 0" limited="true" range="-0.02 0.02" damping="0.5"/>
                      <geom name="gripper_left_geom" type="box" size="0.015 0.005 0.03" material="gripper_mat"/>
                    </body>
                    <!-- Gripper right finger -->
                    <body name="gripper_right" pos="0 0.025 0">
                      <joint name="gripper_right_joint" type="slide" axis="0 1 0"
                             pos="0 0 0" limited="true" range="-0.02 0.02" damping="0.5"/>
                      <geom name="gripper_right_geom" type="box" size="0.015 0.005 0.03" material="gripper_mat"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- Overhead camera -->
    <body name="camera_frame" pos="0 0 2.0">
      <geom name="camera_housing" type="box" size="0.01 0.01 0.01" rgba="0 0 1 1"/>
      <camera name="overhead" mode="fixed" pos="0 0 0" euler="-1.5708 0 0" fovy="45"/>
    </body>
  </worldbody>

  <!-- Actuators -->
  <actuator>
    <motor joint="joint1" name="actuator_joint1" gear="50" ctrlrange="-1 1"/>
    <motor joint="joint2" name="actuator_joint2" gear="50" ctrlrange="-1 1"/>
    <motor joint="joint3" name="actuator_joint3" gear="50" ctrlrange="-1 1"/>
    <motor joint="joint4" name="actuator_joint4" gear="40" ctrlrange="-1 1"/>
    <motor joint="joint5" name="actuator_joint5" gear="40" ctrlrange="-1 1"/>
    <motor joint="joint6" name="actuator_joint6" gear="40" ctrlrange="-1 1"/>
    <motor joint="gripper_left_joint" name="actuator_gripper_left" gear="10" ctrlrange="-1 1"/>
    <motor joint="gripper_right_joint" name="actuator_gripper_right" gear="10" ctrlrange="-1 1"/>
  </actuator>

  <!-- Equality constraints for magnetic grasping -->
  <equality>
    <weld body1="ee_mount" body2="object" anchor="0 0 0" solref="0.02 1" solimp="0.9 0.95 0.001" active="false" name="grasp_weld"/>
  </equality>

</mujoco>
